[Unit]
Description=FundScope Web Server (serve.py)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/fundscope
EnvironmentFile=/home/ubuntu/fundscope/.env
ExecStart=/home/ubuntu/fundscope/.venv/bin/python /home/ubuntu/fundscope/serve.py 8080
Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fundscope-web

[Install]
WantedBy=multi-user.target
